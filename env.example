# Azure Configuration
AZURE_SUBSCRIPTION_ID=your_subscription_id_here
AZURE_RESOURCE_GROUP=healthcare-assistant-rg
AZURE_WORKSPACE_NAME=healthcare-ml-workspace
AZURE_STORAGE_ACCOUNT=your_storage_account_name
AZURE_STORAGE_KEY=your_storage_account_key

# Flask Configuration
SECRET_KEY=your_secret_key_here
FLASK_DEBUG=False
CORS_ORIGINS=http://localhost:3000,http://localhost:5000

# Model Configuration
DIABETES_THRESHOLD=0.5
HEART_DISEASE_THRESHOLD=0.5
EYE_DISEASE_THRESHOLD=0.5

# Azure Static Web Apps (optional)
AZURE_STATIC_WEB_APP_TOKEN=your_static_web_app_token
